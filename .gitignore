# Secrets
.env
.env.linux
**/.env
**/.env.*
!**/.env.example

# Logs
*.log
file.log

# Backups and SQL Dumps
vol_bkup/*
!vol_bkup/.gitkeep
*.sql.gz
backup/
scripts/backup/

# Data Directories
# Ignore all contents but keep the directory via .gitkeep
data/**/*
!data/**/.gitkeep
lan-apps/data/**/*
!lan-apps/data/**/.gitkeep
proxied-apps/data/**/*
!proxied-apps/data/**/.gitkeep

# Legacy / Specific Data Ignores (mostly covered by data/ above)
pia-shared/
.pihole/
pinchflat
derbynet_data/
budget_data/
audiobookshelf_data/
next_cloud_data/
creative_data/
survival_data/

# Python
__pycache__/
*.pyc
.pytest_cache/
