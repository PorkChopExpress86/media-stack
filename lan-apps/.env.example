# ── General ───────────────────────────────────────────────────────────────────
TZ=America/Chicago

# ── Pinchflat ─────────────────────────────────────────────────────────────────
PINCHFLAT_DOWNLOADS=

# ── Plex ──────────────────────────────────────────────────────────────────────
PLEX_CLAIM=

# ── Kometa ────────────────────────────────────────────────────────────────────
# Kometa config lives in its /config volume.
# Do not commit real Plex tokens or TMDb API keys.
PLEX_URL=http://plex:32400
PLEX_TOKEN=
TMDB_API_KEY=

# ── Shared media library paths ────────────────────────────────────────────────
MOVIES=
OTHER_MOVIES=
TV_SHOWS=
OTHER_SHOWS=
KIDS_MOVIES=
KIDS_TV_SHOWS=
MUSIC=
HOME_MOVIES=
