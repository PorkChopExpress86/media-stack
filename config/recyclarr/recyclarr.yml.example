            enabled: false
          - name: WEBRip-1080p
            enabled: false
          - name: Bluray-1080p
            enabled: false
          - name: Bluray-1080p Remux
            enabled: false

    # Minimal low-risk CF pack for 1080p profiles:
    # - Prefer x265 for smaller files
    # - Penalize oversized lossless audio tracks
    # - Hard-penalize 2160p for 1080p profiles as extra guardrail
    custom_formats:
      - trash_ids:
          - 47435ece6b99a0b477caf360e79ba0bb # x265 (HD)
        assign_scores_to:
          - name: 1080p Small WEB
            score: 160
          - name: 1080p Standard
            score: 100
      - trash_ids:
          - c429417a57ea8c41d57e6990a8b0033f # DTS-HD MA
          - 1808e4b9cee74e064dfae3f1db99dbfe # TrueHD
          - 0d7824bb924701997f874e7ff7d4844a # TrueHD ATMOS
          - b6fbafa7942952a13e17e2b1152b539a # ATMOS (undefined)
        assign_scores_to:
          - name: 1080p Small WEB
            score: -175
          - name: 1080p Standard
            score: -75
      - trash_ids:
          - 1bef6c151fa35093015b0bfef18279e5 # 2160p
        assign_scores_to:
          - name: 1080p Small WEB
            score: -10000
          - name: 1080p Standard
            score: -500
      - trash_ids:
          - 9965a052eb87b0d10313b1cea89eb451 # Remux Tier 01
          - 8a1d0c3d7497e741736761a1da866a2e # Remux Tier 02
        assign_scores_to:
          - name: 1080p Small WEB
            score: -400

    # If you manage quality-definition limits via Recyclarr, tune 1080p around:
    # min: 900-1200 MB/h, preferred: 1800-2200 MB/h, max: 2400-2500 MB/h.
    # If not managed here, set equivalent limits in Sonarr UI quality settings.
