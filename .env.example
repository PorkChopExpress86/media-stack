# Docker Compose project name (keeps volume names consistent if directory is renamed)
COMPOSE_PROJECT_NAME=media-stack

# Download paths
qbittorrent_downloads=
pinchflat_downloads=

# Media library paths
movies=
other_movies=
tv_shows=
other_shows=
kids_movies=
kids_tv_shows=
music=
podcasts=
audiobooks=
home_movies=

# Network configuration
jellyfin_url=

# VPN configuration (Private Internet Access)
vpn_username=
vpn_password=

# Plex specific
plex_claim=

# Grafana admin credentials for the monitoring stack
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Backup compression tuning (1=fastest/larger, 9=slowest/smaller)
BACKUP_GZIP_LEVEL=6
# Backup compressor: auto, pigz, or gzip
BACKUP_COMPRESSOR=auto

# *arr API keys (used by Decluttarr)
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=

# qBittorrent credentials (used by Decluttarr)
QBITTORRENT_USER=
QBITTORRENT_PASS=

# Jellyseerr
# Configure Jellyseerr from the web UI after first launch.
jellyseerr_url=

# Recyclarr
# Recyclarr config lives in its /config volume.
# Use these URLs inside recyclarr.yml:
# Radarr: http://vpn:7878
# Sonarr: http://vpn:8989

# Kometa
# Kometa config lives in its /config volume.
# Do not commit real Plex tokens or TMDb API keys.
PLEX_URL=http://plex:32400
PLEX_TOKEN=
TMDB_API_KEY=

# Scrutiny
# Add disk device mappings manually in monitoring/compose.yml before enabling full drive monitoring.
# Examples:
# /dev/sda:/dev/sda
# /dev/nvme0:/dev/nvme0

# You can find documentation for all the supported env variables at https://immich.app/docs/install/environment-variables

# The location where your uploaded files are stored
UPLOAD_LOCATION=
# The location where your database files are stored
DB_DATA_LOCATION=

# Redis password for Immich
REDIS_PASSWORD=

# To set a timezone, change the line below to your preferred TZ identifier (tz database)
TZ=America/Chicago

# The Immich version to use. You can pin this to a specific version like "v1.71.0"
IMMICH_VERSION=v2

# Optional machine-learning image tag override. Keep this equal to IMMICH_VERSION for CPU/default ML.
# For hardware acceleration, use an Immich ML backend tag such as v2-cuda or v2-openvino.
IMMICH_ML_VERSION=v2

# Connection secret for postgres. You should change it to a random password
DB_PASSWORD=

# The values below this line do not need to be changed
###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_IMAGE=docker.io/tensorchord/pgvecto-rs:pg14-v0.2.0@sha256:90724186f0a3517cf6914295b5ab410db9ce23190a2d9d0b9dd6463e3fa298f0
